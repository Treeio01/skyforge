APP_NAME=SKYFORGE
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ──────────────────────────────────────────
# Logging
# ──────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ──────────────────────────────────────────
# Database (MySQL)
# ──────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=skyforge
DB_USERNAME=root
DB_PASSWORD=

# ──────────────────────────────────────────
# Redis
# ──────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ──────────────────────────────────────────
# Session
# ──────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ──────────────────────────────────────────
# Cache, Queue, Broadcast
# ──────────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

# ──────────────────────────────────────────
# Laravel Reverb (WebSocket)
# ──────────────────────────────────────────
REVERB_APP_ID=skyforge-local
REVERB_APP_KEY=skyforge-key
REVERB_APP_SECRET=skyforge-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ──────────────────────────────────────────
# Laravel Horizon
# ──────────────────────────────────────────
HORIZON_NAME=skyforge

# ──────────────────────────────────────────
# Steam Auth (Socialite)
# ──────────────────────────────────────────
STEAM_CLIENT_SECRET=  # Steam Web API Key — https://steamcommunity.com/dev/apikey
STEAM_CALLBACK_URL="${APP_URL}/auth/steam/callback"

# ──────────────────────────────────────────
# SKYFORGE App Settings
# ──────────────────────────────────────────
SKYFORGE_HOUSE_EDGE=5.00
SKYFORGE_MIN_BET=100
SKYFORGE_MAX_BET=5000000
SKYFORGE_MIN_CHANCE=1.00
SKYFORGE_MAX_CHANCE=95.00
SKYFORGE_UPGRADE_COOLDOWN=2

# Price sync
SKYFORGE_PRICE_SYNC_ENABLED=true
SKYFORGE_PRICE_SYNC_INTERVAL=15
SKYFORGE_PRICE_SOURCE_URL=https://market.csgo.com/api/v2/prices/RUB.json
SKYFORGE_PRICE_CHANGE_THRESHOLD=5.0

# Skins storage
SKYFORGE_SKINS_DISK=public
SKYFORGE_SKINS_PATH=skins

# ──────────────────────────────────────────
# Payment Provider
# ──────────────────────────────────────────
SKYFORGE_PAYMENT_PROVIDER=stub
SKYFORGE_PAYMENT_API_KEY=
SKYFORGE_PAYMENT_API_SECRET=
SKYFORGE_PAYMENT_WEBHOOK_SECRET=

# ──────────────────────────────────────────
# MoonShine Admin
# ──────────────────────────────────────────
MOONSHINE_TITLE=SKYFORGE
MOONSHINE_ROUTE_PREFIX=admin

# ──────────────────────────────────────────
# Vite
# ──────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
